#include <stdio.h>
#include <string.h>

struct Process {
    char id[10];
    int at, bt, pr, ct, wt, tat, completed;
};

int main() {
    int n;
    scanf("%d", &n);
    struct Process p[n];

    for (int i = 0; i < n; i++) {
        scanf("%s %d %d %d", p[i].id, &p[i].at, &p[i].bt, &p[i].pr);
        p[i].completed = 0;
    }

    int currentTime = 0, completedCount = 0;
    float totalWT = 0, totalTAT = 0;

    while (completedCount < n) {
        int idx = -1;
        int maxPriority = -1;

        // Find the process with highest priority among those that have arrived
        for (int i = 0; i < n; i++) {
            if (p[i].at <= currentTime && !p[i].completed) {
                if (p[i].pr > maxPriority) {
                    maxPriority = p[i].pr;
                    idx = i;
                }
                // If priorities are equal, pick the one with earliest arrival (FCFS tie-break)
                else if (p[i].pr == maxPriority) {
                    if (p[i].at < p[idx].at) {
                        idx = i;
                    }
                }
            }
        }

        if (idx != -1) {
            p[idx].wt = currentTime - p[idx].at;
            currentTime += p[idx].bt;
            p[idx].tat = p[idx].wt + p[idx].bt;
            p[idx].completed = 1;
            completedCount++;
            totalWT += p[idx].wt;
            totalTAT += p[idx].tat;
        } else {
            // If no process has arrived, advance time
            currentTime++;
        }
    }

    // Output formatting
    printf("Waiting Time:\n");
    for (int i = 0; i < n; i++) {
        printf("%s %d\n", p[i].id, p[i].wt);
    }

    printf("Turnaround Time:\n");
    for (int i = 0; i < n; i++) {
        printf("%s %d\n", p[i].id, p[i].tat);
    }

    printf("Average Waiting Time: %.2f\n", totalWT / n);
    printf("Average Turnaround Time: %.2f\n", totalTAT / n);

    return 0;
}
